# 依赖与构建产物（通用 + 多生态）
node_modules/
dist/
build/
coverage/
target/
vendor/

# 日志与临时文件
*.log
*.tmp
.DS_Store

# S2V fixture 是测试事实源 —— 必须入库，豁免上面的通用忽略（*.log/*.tmp 等）
# （含 secret-redaction 用的伪造 .env/.log fixture：内容为假凭证，作为测试事实源须 track）
!test/fixtures/
!test/fixtures/**

# IDE / 编辑器配置
.idea/
.vscode/
*.swp

# 语言特定（本项目 = Go 控制面 + Rust 数据面，按步 2 解析技术栈补全）
# Go:
#   仓库根锚定二进制名（前导 / 防止误吞 cmd/contextforge/ 同名源码目录 — init.md 步 11 警告）
/contextforge
/contextforge-core
/contextforge.exe
/contextforge-core.exe
*.test
*.out
# 注意：go.sum 必须入库（依赖完整性），不忽略
# Rust:
#   target/ 已在上方；Cargo.lock 对二进制应用须入库（不忽略）
**/*.rs.bk

# _dispatch 子目录约定：顶层 README + reviewer template tracked（规范文档）；
# sessions/ 仅本地：历史归档（archive/，2026-05-23 前 team 多终端遗留）+ 偶发本地协作临时产物，不入库。
# 单驱动变体（ADR-011）下新流程不再产出 sessions/ 内容，但 archive/ 保留供历史复盘。
_dispatch/sessions/

# docs/playbooks/ 是个人 /goal 操作 playbook，文件 header 自标 "不入 git"
# 仅本地保留供操作参考；勿用 git add -A 误扫入
docs/playbooks/

# Claude Code local session state (cron / scheduled wakeups / etc.) — local only.
.claude/
